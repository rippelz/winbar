#!/usr/bin/env python3
# ============================================================
# winbar-dock — Windows-style grouped taskbar for Hyprland.
#
# Sits on top of the winmode waybar (which reserves the space
# and draws the background) and provides the app area:
#   - pinned + running apps merged (no duplicates)
#   - indicator underline: none = pinned only, grey = running,
#     blue = focused; count badge when multiple windows
#   - left click:  launch / focus / window picker
#   - hover:       thumbnail preview popup, centered above icon
#   - right click: pin / unpin / new window / close
#   - hold + drag icons left/right to reorder (icons shuffle
#     live under the cursor; pinned order persists)
#   - hides while a window is fullscreen on its monitor
#
# Thumbnails: whenever a window gains focus it is snapshotted
# with grim (scaled jpeg, atomic rename) into
# ~/.cache/winbar/thumbs so previews show real window content.
#
# Pinned apps: ~/.config/winbar/pinned.json (list of .desktop ids)
# ============================================================

import ctypes
import hashlib
import json
import os
import shutil
import socket
import subprocess
import sys
import threading
import urllib.request

# name the process so pgrep/pkill -x winbar-dock works
try:
    libc = ctypes.CDLL('libc.so.6')
    libc.prctl(15, b'winbar-dock', 0, 0, 0)  # PR_SET_NAME
except Exception:
    pass

import warnings
