#!/usr/bin/env bash
# toggle-waybar — hide / show waybar (mode-aware: normal vs windows bar).
#
# In winmode the taskbar is waybar (strip) + winbar-dock (app icons).
# Both must hide/show together, and dock must map AFTER waybar so
# icons stack above the strip (both are overlay-layer surfaces).
set -u

WINMODE=0
[ -e "$HOME/.local/state/winmode/on" ] && WINMODE=1

chrome_up() {
    pgrep -x waybar >/dev/null 2>&1 && return 0
    [ "$WINMODE" -eq 1 ] && pgrep -x winbar-dock >/dev/null 2>&1 && return 0
    return 1
}

if chrome_up; then
    pkill -x waybar 2>/dev/null || true
    if [ "$WINMODE" -eq 1 ]; then
        pkill -x winbar-dock 2>/dev/null || true
    fi
    exit 0
fi

# restart matching current desktop mode
if [ "$WINMODE" -eq 1 ]; then
    setsid -f waybar \
        -c "$HOME/.config/waybar/windows/config.jsonc" \
        -s "$HOME/.config/waybar/windows/style.css" >/dev/null 2>&1

    # dock after waybar for within-overlay z-order
    (
        sleep 0.35
        [ -e "$HOME/.local/state/winmode/on" ] || exit 0
        pgrep -x waybar >/dev/null 2>&1 || exit 0
        pkill -x winbar-dock 2>/dev/null || true
        for _ in $(seq 20); do
            pgrep -x winbar-dock >/dev/null 2>&1 || break
            sleep 0.05
        done
        setsid -f "$HOME/.local/bin/winbar-dock" >/dev/null 2>&1
    ) &
else
    setsid -f waybar >/dev/null 2>&1
fi
