#!/usr/bin/env bash
# ============================================================
# winmode-boot — run by hyprland exec-once at login.
# Starts the bar (and taskbar + desktop icons) matching the
# saved mode, so windows mode survives reboots.
# ============================================================
set -u

# clipboard history collector (WIN+V in windows mode)
if command -v cliphist >/dev/null 2>&1; then
    pgrep -f 'wl-paste.*cliphist' >/dev/null 2>&1 || {
        setsid -f wl-paste --type text --watch cliphist store >/dev/null 2>&1
        setsid -f wl-paste --type image --watch cliphist store >/dev/null 2>&1
    }
fi

# rofi app order tracks real recent usage (respect hyprmods install state)
_app_recency_wanted=1
if command -v hyprmods >/dev/null 2>&1; then
    hyprmods check app-recency >/dev/null 2>&1 || _app_recency_wanted=0
fi
if [ "$_app_recency_wanted" -eq 1 ] && [ -x "$HOME/.local/bin/app-recency" ]; then
    if ! pgrep -f '[a]pp-recency' >/dev/null 2>&1; then
        setsid -f "$HOME/.local/bin/app-recency" daemon >/dev/null 2>&1
    fi
fi

# titlebar minimize plugin (only acts while winmode is on)
if [ -f "$HOME/.local/lib/hypr-minimize.so" ]; then
    hyprctl plugin list 2>/dev/null | grep -q 'hypr-minimize' || \
        hyprctl plugin load "$HOME/.local/lib/hypr-minimize.so" >/dev/null 2>&1 || true
fi

exec "$HOME/.local/bin/winmode-chrome" boot
